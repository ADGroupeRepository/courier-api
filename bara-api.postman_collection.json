    {
      "name": "Organisations",
      "description": "Routes de gestion des organisations (CRUD complet).",
      "item": [
        {
          "name": "Lister les organisations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/organisations",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "organisations"
              ]
            },
            "description": "Affiche la liste des organisations auxquelles l'utilisateur appartient."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Le statut doit être 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Créer une organisation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corporation\",\n  \"description\": \"Fabricant d'enclumes\",\n  \"address\": \"123 Rue de l'Industrie\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/organisations",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "organisations"
              ]
            },
            "description": "Crée une nouvelle organisation et définit l'utilisateur comme propriétaire."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Le statut est soit 201 (Créé) soit 200 (OK)\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test(\"Enregistre l'ID de l'organisation dans les variables\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData && jsonData.id) {",
                  "        pm.collectionVariables.set(\"orgId\", jsonData.id);",
                  "    } else if (jsonData && jsonData.data && jsonData.data.id) {",
                  "        pm.collectionVariables.set(\"orgId\", jsonData.data.id);",
                  "    } else if (jsonData && jsonData.data && jsonData.data.$id) {",
                  "        pm.collectionVariables.set(\"orgId\", jsonData.data.$id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Voir une organisation",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
