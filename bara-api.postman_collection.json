    {
      "name": "Membres de l'Organisation",
      "description": "Gestion des membres au sein d'une organisation.",
      "item": [
        {
          "name": "Lister les membres",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/organisations/{{orgId}}/members",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "organisations",
                "{{orgId}}",
                "members"
              ]
            },
            "description": "Affiche tous les membres d'une organisation donnée."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Le statut doit être 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Ajouter un membre",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nouveau.membre@example.com\",\n  \"roles\": [\"admin\", \"user\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/organisations/{{orgId}}/members",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "organisations",
                "{{orgId}}",
                "members"
              ]
            },
            "description": "Ajoute un nouvel utilisateur ou invite un utilisateur existant à rejoindre l'organisation."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Le statut est soit 201 (Créé) soit 200 (OK)\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test(\"Enregistre l'ID du membre dans les variables\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData && jsonData.id) {",
                  "        pm.collectionVariables.set(\"memberId\", jsonData.id);",
                  "    } else if (jsonData && jsonData.data && jsonData.data.id) {",
                  "        pm.collectionVariables.set(\"memberId\", jsonData.data.id);",
                  "    } else if (jsonData && jsonData.data && jsonData.data.$id) {",
                  "        pm.collectionVariables.set(\"memberId\", jsonData.data.$id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
